# Public API base (include /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Canonical site URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Brand name used in metadata and OG images
NEXT_PUBLIC_SITE_NAME=ToolVerse AI

# Set to "true" to render AdSense slots (space is always reserved)
NEXT_PUBLIC_ADSENSE_ENABLED=false

# Optional AdSense publisher id (used when ads enabled)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx

# Server-side API URL when calling from RSC behind Docker network
API_INTERNAL_URL=http://localhost:8000/api/v1

# Supabase (browser + SSR clients)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Sentry (optional — leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# AI provider keys belong on the Django API only (server-side).
# Do NOT add OPENAI_API_KEY, ANTHROPIC_API_KEY, or similar to this Next.js app.
# The web app calls /api/v1/ai/* with the user's JWT; the API holds provider secrets.
# NEXT_PUBLIC_* variables below remain the only browser-exposed configuration.
# ---------------------------------------------------------------------------
