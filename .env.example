# =============================================================================
# ToolVerse AI — Environment Variables
# Copy to .env and adjust for your environment
# =============================================================================

# --- General ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=true
USE_SQLITE=false
ALLOWED_HOSTS=localhost,127.0.0.1,api,web,testserver
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost

# --- Database (PostgreSQL) ---
POSTGRES_DB=toolverse
POSTGRES_USER=toolverse
POSTGRES_PASSWORD=toolverse_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://toolverse:toolverse_secret@postgres:5432/toolverse

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Frontend ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_NAME=ToolVerse AI
NEXT_PUBLIC_DEFAULT_LOCALE=en
API_INTERNAL_URL=http://api:8000/api/v1

# --- AdSense (leave empty to hide ads; layout slots remain reserved) ---
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_ENABLED=false

# --- Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# --- Backups & Celery monitoring ---
BACKUP_ENABLED=false
BACKUP_DIR=./backups
FLOWER_BASIC_AUTH=admin:changeme

# --- Referrals (optional tuning) ---
REFERRAL_COOKIE_DAYS=30
REFERRAL_DAILY_SIGNUP_CAP=20
REFERRAL_REWARD_POINTS=100

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=toolverse
R2_PUBLIC_URL=
R2_ENDPOINT_URL=

# --- Email (optional) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@toolverse.ai

# --- Rate limiting ---
RATE_LIMIT_ANON=60/minute
RATE_LIMIT_USER=120/minute

# --- AI providers (server-side only; never expose to Next.js public env) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
AI_DEFAULT_PROVIDER=openai
AI_FALLBACK_PROVIDERS=openrouter,deepseek
AI_OPENROUTER_REFERER=https://toolverse.ai

# --- API marketplace ---
API_KEY_PEPPER=

# --- Google Search Console (service account JSON string or file path) ---
GSC_CREDENTIALS_JSON=
GSC_CREDENTIALS_FILE=
GSC_SITE_URL=https://toolverse.ai/

# --- Web Push (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@toolverse.ai

# --- Content Autopilot ---
# When false (default), autopilot stops at human_review and requires approve
AUTOPILOT_AUTO_PUBLISH=false
